<script type="application/json" data-product-json>
  {{ product | json }}
</script>

<section class="py-12 sm:py-16 lg:py-24 px-4 sm:px-6 lg:px-8" data-product-section>
  <div class="max-w-7xl mx-auto">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-8 lg:gap-16">

      <div class="space-y-3">
        {% for media in product.media %}
          <div class="glass-surface rounded-3xl overflow-hidden haptic-hover {% if forloop.first %}aspect-square{% else %}aspect-[4/3]{% endif %}">
            {% if media.media_type == 'image' %}
              <img
                src="{{ media | image_url: width: 1200 }}"
                alt="{{ media.alt | escape }}"
                width="{{ media.width }}"
                height="{{ media.height }}"
                {% if forloop.first %}loading="eager" fetchpriority="high"{% else %}loading="lazy"{% endif %}
                class="w-full h-full object-cover"
              >
            {% elsif media.media_type == 'video' %}
              {{ media | video_tag: autoplay: true, muted: true, loop: true, class: 'w-full h-full object-cover' }}
            {% endif %}
          </div>
        {% else %}
          <div class="glass-surface rounded-3xl aspect-square flex items-center justify-center">
            <svg width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1" class="text-white/20">
              <rect x="3" y="3" width="18" height="18" rx="2" ry="2"></rect>
              <circle cx="8.5" cy="8.5" r="1.5"></circle>
              <polyline points="21 15 16 10 5 21"></polyline>
            </svg>
          </div>
        {% endfor %}
      </div>

      <div class="lg:sticky lg:top-28 lg:self-start">
        <div class="space-y-6">
          {% for block in section.blocks %}
            {% case block.type %}

              {% when 'vendor' %}
                {% if product.vendor != blank %}
                  <p class="text-sm font-medium text-white/40 uppercase tracking-wider" {{ block.shopify_attributes }}>
                    {{ product.vendor }}
                  </p>
                {% endif %}

              {% when 'title' %}
                <h1 class="text-3xl sm:text-4xl lg:text-5xl font-bold tracking-tight text-white" {{ block.shopify_attributes }}>
                  {{ product.title }}
                </h1>

              {% when 'price' %}
                <div class="flex items-baseline gap-3" {{ block.shopify_attributes }}>
                  <span class="text-2xl font-semibold text-white" data-product-price>
                    {{ product.selected_or_first_available_variant.price | money }}
                  </span>
                  {% if product.selected_or_first_available_variant.compare_at_price > product.selected_or_first_available_variant.price %}
                    <span class="text-lg text-white/40 line-through" data-product-compare-price>
                      {{ product.selected_or_first_available_variant.compare_at_price | money }}
                    </span>
                    <span class="px-2.5 py-0.5 text-xs font-semibold bg-red-500/20 text-red-400 rounded-full">
                      {{ 'product.on_sale' | t }}
                    </span>
                  {% endif %}
                </div>

              {% when 'variant_picker' %}
                {% unless product.has_only_default_variant %}
                  <div {{ block.shopify_attributes }}>
                    {% for option in product.options_with_values %}
                      <fieldset class="mb-4">
                        <legend class="text-sm font-medium text-white/60 mb-3">{{ option.name }}</legend>
                        <div class="flex flex-wrap gap-2">
                          {% for value in option.values %}
                            <label class="relative cursor-pointer">
                              <input
                                type="radio"
                                name="{{ option.name }}"
                                value="{{ value | escape }}"
                                class="sr-only peer"
                                {% if option.selected_value == value %}checked{% endif %}
                                data-option-selector
                              >
                              <span class="inline-flex items-center px-4 py-2.5 text-sm font-medium text-white/70 bg-white/5 border border-white/[0.08] rounded-xl peer-checked:bg-white peer-checked:text-black peer-checked:border-white peer-focus-visible:ring-2 peer-focus-visible:ring-white/50 transition-all hover:bg-white/10 cursor-pointer">
                                {{ value }}
                              </span>
                            </label>
                          {% endfor %}
                        </div>
                      </fieldset>
                    {% endfor %}
                  </div>
                {% endunless %}

              {% when 'quantity_selector' %}
                <div {{ block.shopify_attributes }}>
                  <label for="product-quantity" class="text-sm font-medium text-white/60 mb-3 block">{{ 'product.quantity' | t }}</label>
                  <div class="inline-flex items-center gap-0 glass-surface rounded-xl overflow-hidden">
                    <button
                      class="w-12 h-12 flex items-center justify-center text-white/60 hover:text-white hover:bg-white/10 transition-colors focus:outline-none focus:ring-2 focus:ring-inset focus:ring-white/30"
                      data-quantity-minus
                      aria-label="{{ 'product.decrease_quantity' | t }}"
                    >
                      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="5" y1="12" x2="19" y2="12"></line></svg>
                    </button>
                    <input
                      type="number"
                      id="product-quantity"
                      name="quantity"
                      min="1"
                      value="1"
                      class="w-14 h-12 text-center text-white bg-transparent border-x border-white/[0.08] text-sm font-medium focus:outline-none"
                      data-quantity-input
                    >
                    <button
                      class="w-12 h-12 flex items-center justify-center text-white/60 hover:text-white hover:bg-white/10 transition-colors focus:outline-none focus:ring-2 focus:ring-inset focus:ring-white/30"
                      data-quantity-plus
                      aria-label="{{ 'product.increase_quantity' | t }}"
                    >
                      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="12" y1="5" x2="12" y2="19"></line><line x1="5" y1="12" x2="19" y2="12"></line></svg>
                    </button>
                  </div>
                </div>

              {% when 'buy_buttons' %}
                <div class="space-y-3" {{ block.shopify_attributes }}>
                  {% form 'product', product, data-product-form: '' %}
                    <input type="hidden" name="id" value="{{ product.selected_or_first_available_variant.id }}" data-variant-id>
                    <input type="hidden" name="quantity" value="1" data-form-quantity>

                    <button
                      type="submit"
                      class="w-full py-4 bg-white text-black rounded-2xl font-semibold text-sm hover:bg-white/90 transition-all focus:outline-none focus:ring-2 focus:ring-white/50 disabled:opacity-50 disabled:cursor-not-allowed"
                      {% unless product.selected_or_first_available_variant.available %}disabled{% endunless %}
                      data-add-to-cart
                    >
                      {% if product.selected_or_first_available_variant.available %}
                        {{ 'product.add_to_cart' | t }}
                      {% else %}
                        {{ 'product.sold_out' | t }}
                      {% endif %}
                    </button>

                    {% if block.settings.show_dynamic_checkout %}
                      <div class="shopify-payment-button rounded-2xl overflow-hidden mt-3">
                        {{ form | payment_button }}
                      </div>
                    {% endif %}
                  {% endform %}
                </div>

              {% when 'description' %}
                {% if product.description != blank %}
                  <div class="glass-surface rounded-2xl p-6" {{ block.shopify_attributes }}>
                    <details open>
                      <summary class="flex items-center justify-between cursor-pointer text-sm font-semibold text-white focus:outline-none focus-visible:ring-2 focus-visible:ring-white/30 rounded">
                        {{ 'product.description' | t }}
                        <svg class="w-4 h-4 text-white/40 transition-transform" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="6 9 12 15 18 9"></polyline></svg>
                      </summary>
                      <div class="mt-4 text-sm text-white/60 leading-relaxed prose prose-invert prose-sm max-w-none">
                        {{ product.description }}
                      </div>
                    </details>
                  </div>
                {% endif %}

              {% when '@app' %}
                <div {{ block.shopify_attributes }}>
                  {% render block %}
                </div>

            {% endcase %}
          {% endfor %}
        </div>
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Product Page",
  "tag": "section",
  "class": "main-product-section",
  "blocks": [
    {
      "type": "vendor",
      "name": "Vendor",
      "limit": 1
    },
    {
      "type": "title",
      "name": "Title",
      "limit": 1
    },
    {
      "type": "price",
      "name": "Price",
      "limit": 1
    },
    {
      "type": "variant_picker",
      "name": "Variant Picker",
      "limit": 1
    },
    {
      "type": "quantity_selector",
      "name": "Quantity Selector",
      "limit": 1
    },
    {
      "type": "buy_buttons",
      "name": "Buy Buttons",
      "limit": 1,
      "settings": [
        {
          "type": "checkbox",
          "id": "show_dynamic_checkout",
          "label": "Show dynamic checkout button",
          "default": true,
          "info": "Uses the customer's preferred payment method (Apple Pay, Google Pay, etc.)"
        }
      ]
    },
    {
      "type": "description",
      "name": "Description",
      "limit": 1
    },
    {
      "type": "@app"
    }
  ]
}
{% endschema %}