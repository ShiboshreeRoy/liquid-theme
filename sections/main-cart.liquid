<section class="py-12 sm:py-16 lg:py-24 px-4 sm:px-6 lg:px-8">
  <div class="max-w-3xl mx-auto">
    <h1 class="text-3xl sm:text-4xl font-bold tracking-tight text-white mb-8">{{ 'cart.title' | t }}</h1>

    {% if cart.item_count == 0 %}
      <div class="glass-surface rounded-3xl p-12 text-center">
        <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="mx-auto mb-4" style="color:rgba(255,255,255,0.3)">
          <path d="M6 2L3 6v14a2 2 0 002 2h14a2 2 0 002-2V6l-3-4z"></path>
          <line x1="3" y1="6" x2="21" y2="6"></line>
          <path d="M16 10a4 4 0 01-8 0"></path>
        </svg>
        <p class="text-white/50 text-sm mb-6">{{ 'cart.empty' | t }}</p>
        <a href="/collections/all" class="inline-flex px-6 py-3 bg-white text-black rounded-full text-sm font-semibold hover:bg-white/90 transition-colors focus:outline-none focus:ring-2 focus:ring-white/50">
          {{ 'cart.continue_shopping' | t }}
        </a>
      </div>
    {% else %}
      <form action="/cart" method="post" novalidate>
        <div class="space-y-4 mb-8">
          {% for item in cart.items %}
            <div class="glass-surface rounded-2xl p-4 flex gap-4">
              <div class="w-20 h-20 rounded-xl overflow-hidden flex-shrink-0 bg-white/5">
                {% if item.image %}
                  <img
                    src="{{ item.image | image_url: width: 200 }}"
                    alt="{{ item.title | escape }}"
                    width="80"
                    height="80"
                    loading="lazy"
                    class="w-full h-full object-cover"
                  >
                {% endif %}
              </div>
              <div class="flex-1 min-w-0">
                <a href="{{ item.url }}" class="text-sm font-medium text-white hover:text-white/80 transition-colors truncate block focus:outline-none focus:ring-2 focus:ring-white/30 rounded">
                  {{ item.product.title }}
                </a>
                {% if item.variant.title != 'Default Title' %}
                  <p class="text-xs text-white/40 mt-0.5">{{ item.variant.title }}</p>
                {% endif %}
                <div class="flex items-center justify-between mt-2">
                  <span class="text-sm font-medium text-white">{{ item.final_line_price | money }}</span>
                  <div class="inline-flex items-center glass-surface rounded-xl overflow-hidden">
                    <button
                      type="button"
                      class="w-8 h-8 flex items-center justify-center text-white/60 hover:text-white hover:bg-white/10 transition-colors focus:outline-none focus:ring-2 focus:ring-inset focus:ring-white/30"
                      name="minus"
                      aria-label="{{ 'product.decrease_quantity' | t }}"
                      onclick="this.parentNode.querySelector('input').stepDown(); this.closest('form').submit();"
                    >
                      <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="5" y1="12" x2="19" y2="12"></line></svg>
                    </button>
                    <input
                      type="number"
                      name="updates[]"
                      value="{{ item.quantity }}"
                      min="0"
                      class="w-10 h-8 text-center text-white bg-transparent border-x border-white/[0.08] text-xs font-medium focus:outline-none"
                      aria-label="Quantity for {{ item.product.title | escape }}"
                    >
                    <button
                      type="button"
                      class="w-8 h-8 flex items-center justify-center text-white/60 hover:text-white hover:bg-white/10 transition-colors focus:outline-none focus:ring-2 focus:ring-inset focus:ring-white/30"
                      name="plus"
                      aria-label="{{ 'product.increase_quantity' | t }}"
                      onclick="this.parentNode.querySelector('input').stepUp(); this.closest('form').submit();"
                    >
                      <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="12" y1="5" x2="12" y2="19"></line><line x1="5" y1="12" x2="19" y2="12"></line></svg>
                    </button>
                  </div>
                </div>
              </div>
            </div>
          {% endfor %}
        </div>

        <div class="glass-surface rounded-2xl p-6">
          <div class="flex items-center justify-between mb-4">
            <span class="text-sm text-white/60">{{ 'cart.subtotal' | t }}</span>
            <span class="text-xl font-semibold text-white">{{ cart.total_price | money }}</span>
          </div>
          <p class="text-xs text-white/40 mb-4">Shipping and taxes calculated at checkout.</p>
          <button
            type="submit"
            name="checkout"
            class="w-full py-4 bg-white text-black rounded-2xl font-semibold text-sm hover:bg-white/90 transition-colors focus:outline-none focus:ring-2 focus:ring-white/50"
          >
            {{ 'cart.checkout' | t }}
          </button>
        </div>
      </form>
    {% endif %}
  </div>
</section>

{% schema %}
{
  "name": "Cart Page",
  "tag": "section",
  "class": "main-cart-section"
}
{% endschema %}