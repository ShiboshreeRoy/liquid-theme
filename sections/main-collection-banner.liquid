<section class="py-12 sm:py-16 px-4 sm:px-6 lg:px-8">
  <div class="max-w-7xl mx-auto">
    <div class="glass-surface rounded-3xl p-8 sm:p-12 relative overflow-hidden">
      {% if collection.image %}
        <img
          src="{{ collection.image | image_url: width: 1600 }}"
          alt="{{ collection.image.alt | escape }}"
          loading="eager"
          class="absolute inset-0 w-full h-full object-cover opacity-20"
        >
      {% endif %}
      <div class="relative z-10">
        <h1 class="text-3xl sm:text-4xl lg:text-5xl font-bold tracking-tight text-white mb-3">
          {{ collection.title }}
        </h1>
        {% if collection.description != blank %}
          <p class="text-base sm:text-lg text-white/60 max-w-2xl leading-relaxed">
            {{ collection.description }}
          </p>
        {% endif %}
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Collection Banner",
  "tag": "section",
  "class": "collection-banner-section"
}
{% endschema %}