<footer class="border-t border-white/[0.06]" role="contentinfo">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">

    <div class="grid grid-cols-2 md:grid-cols-4 gap-8 py-12 sm:py-16">
      {% for block in section.blocks %}
        {% case block.type %}
          {% when 'link_list' %}
            <div {{ block.shopify_attributes }}>
              <h3 class="text-sm font-semibold text-white mb-4">{{ block.settings.heading }}</h3>
              {% if block.settings.menu != blank %}
                <ul class="space-y-3" role="list">
                  {% for link in linklists[block.settings.menu].links %}
                    <li>
                      <a
                        href="{{ link.url }}"
                        class="text-sm text-white/50 hover:text-white transition-colors focus:outline-none focus:ring-2 focus:ring-white/30 rounded"
                        {% if link.active %}aria-current="page"{% endif %}
                      >
                        {{ link.title }}
                      </a>
                    </li>
                  {% endfor %}
                </ul>
              {% endif %}
            </div>

          {% when 'newsletter' %}
            <div class="col-span-2 md:col-span-1" {{ block.shopify_attributes }}>
              <h3 class="text-sm font-semibold text-white mb-4">{{ block.settings.heading | default: 'Stay Updated' }}</h3>
              <p class="text-sm text-white/50 mb-4">{{ block.settings.text | default: 'Subscribe for updates and exclusive offers.' }}</p>
              {% form 'customer', class: 'flex gap-2' %}
                <label for="footer-email" class="sr-only">{{ 'footer.email_placeholder' | t }}</label>
                <input
                  type="email"
                  name="contact[email]"
                  id="footer-email"
                  placeholder="{{ 'footer.email_placeholder' | t }}"
                  required
                  autocomplete="email"
                  class="flex-1 px-4 py-3 bg-white/5 border border-white/[0.08] rounded-xl text-sm text-white placeholder-white/30 focus:outline-none focus:ring-2 focus:ring-white/20 focus:border-white/20 transition-colors"
                >
                <input type="hidden" name="contact[tags]" value="newsletter">
                <button
                  type="submit"
                  class="px-5 py-3 bg-white text-black rounded-xl text-sm font-semibold hover:bg-white/90 transition-colors focus:outline-none focus:ring-2 focus:ring-white/50 whitespace-nowrap"
                >
                  {{ 'footer.subscribe' | t }}
                </button>
              {% endform %}
            </div>
        {% endcase %}
      {% endfor %}
    </div>

    <div class="flex flex-col sm:flex-row items-center justify-between gap-4 py-6 border-t border-white/[0.06]">
      <p class="text-xs text-white/30">
        &copy; {{ 'now' | date: '%Y' }} {{ shop.name }}. {{ 'footer.rights' | t }}
      </p>
      <div class="flex items-center gap-4">
        {% if section.settings.show_payment_icons %}
          <span class="text-xs text-white/30">{{ 'footer.payment_methods' | t }}</span>
        {% endif %}
      </div>
    </div>
  </div>
</footer>

{% schema %}
{
  "name": "Footer",
  "tag": "section",
  "class": "footer-section",
  "settings": [
    {
      "type": "checkbox",
      "id": "show_payment_icons",
      "label": "Show payment icons",
      "default": true
    }
  ],
  "blocks": [
    {
      "type": "link_list",
      "name": "Link List",
      "settings": [
        {
          "type": "text",
          "id": "heading",
          "label": "Heading",
          "default": "Quick Links"
        },
        {
          "type": "link_list",
          "id": "menu",
          "label": "Menu"
        }
      ]
    },
    {
      "type": "newsletter",
      "name": "Newsletter",
      "limit": 1,
      "settings": [
        {
          "type": "text",
          "id": "heading",
          "label": "Heading",
          "default": "Stay Updated"
        },
        {
          "type": "textarea",
          "id": "text",
          "label": "Description",
          "default": "Subscribe for updates and exclusive offers."
        }
      ]
    }
  ],
  "default": {
    "blocks": [
      {
        "type": "link_list",
        "settings": {
          "heading": "Shop",
          "menu": "main-menu"
        }
      },
      {
        "type": "link_list",
        "settings": {
          "heading": "Help",
          "menu": "footer"
        }
      },
      {
        "type": "newsletter"
      }
    ]
  }
}
{% endschema %}