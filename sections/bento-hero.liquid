      "label": "Subheading",
      "default": "Premium products crafted with precision and purpose."
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "Primary button text",
      "default": "Shop Now"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Primary button link"
    },
    {
      "type": "text",
      "id": "secondary_button_text",
      "label": "Secondary button text",
      "default": "Learn More"
    },
    {
      "type": "url",
      "id": "secondary_button_link",
      "label": "Secondary button link"
    },
    {
      "type": "header",
      "content": "Bento Card 1"
    },
    {
      "type": "text",
      "id": "card_1_title",
      "label": "Title",
      "default": "Premium Quality"
    },
    {
      "type": "text",
      "id": "card_1_text",
      "label": "Description",
      "default": "Crafted with the finest materials"
    },
    {
      "type": "image_picker",
      "id": "card_1_image",
      "label": "Background image"
    },
    {
      "type": "header",
      "content": "Bento Card 2"
    },
    {
      "type": "text",
      "id": "card_2_title",
      "label": "Title",
      "default": "Free Shipping"
    },
    {
      "type": "text",
      "id": "card_2_text",
      "label": "Description",
      "default": "Complimentary on all orders"
    },
    {
      "type": "image_picker",
      "id": "card_2_image",
      "label": "Background image"
    },
    {
      "type": "header",
      "content": "Bento Card 3"
    },
    {
      "type": "text",
      "id": "card_3_title",
      "label": "Title",
      "default": "Secure Checkout"
    },
    {
      "type": "text",
      "id": "card_3_text",
      "label": "Description",
      "default": "Encrypted & protected payments"
    },
    {
      "type": "image_picker",
      "id": "card_3_image",
      "label": "Background image"
    },
    {
      "type": "header",
      "content": "Bento Card 4"
    },
    {
      "type": "text",
      "id": "card_4_title",
      "label": "Title",
      "default": "24/7 Support"
    },
    {
      "type": "text",
      "id": "card_4_text",
      "label": "Description",
      "default": "Always here to help you"
    },
    {
      "type": "image_picker",
      "id": "card_4_image",
      "label": "Background image"
    }
  ],
  "presets": [
    {
      "name": "Bento Hero"
    }
  ]
}
{% endschema %}