<section
  class="relative py-12 sm:py-16 lg:py-24 px-4 sm:px-6 lg:px-8 overflow-hidden"
  aria-label="{{ section.settings.heading | escape }}"
  data-bento-hero
>
  <div class="absolute inset-0 overflow-hidden" aria-hidden="true">
    <div class="absolute top-1/4 -left-1/4 w-[600px] h-[600px] bg-blue-500/10 rounded-full blur-[120px]"></div>
    <div class="absolute bottom-1/4 -right-1/4 w-[500px] h-[500px] bg-purple-500/10 rounded-full blur-[120px]"></div>
    <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[800px] h-[800px] bg-indigo-500/5 rounded-full blur-[150px]"></div>
  </div>

  <div class="relative max-w-7xl mx-auto">
    <div class="grid grid-cols-2 md:grid-cols-4 gap-3 sm:gap-4 lg:gap-5 auto-rows-[minmax(140px,1fr)] md:auto-rows-[minmax(180px,1fr)]">

      <div class="col-span-2 row-span-2 glass-surface rounded-3xl p-6 sm:p-8 lg:p-10 flex flex-col justify-between haptic-hover group">
        <div>
          {% if section.settings.eyebrow != blank %}
            <span class="inline-block px-3 py-1 text-xs font-semibold tracking-wider uppercase text-blue-400 bg-blue-500/10 rounded-full mb-4 sm:mb-6">
              {{ section.settings.eyebrow }}
            </span>
          {% endif %}

          <h1 class="text-3xl sm:text-4xl lg:text-5xl xl:text-6xl font-bold tracking-tight text-white leading-[1.08] mb-3 sm:mb-4">
            {{ section.settings.heading }}
          </h1>

          <p class="text-base sm:text-lg text-white/60 max-w-lg leading-relaxed">
            {{ section.settings.subheading }}
          </p>
        </div>

        <div class="flex flex-wrap gap-3 mt-6 sm:mt-8">
          {% if section.settings.button_text != blank %}
            <a
              href="{{ section.settings.button_link }}"
              class="inline-flex items-center px-6 py-3 bg-white text-black rounded-full text-sm font-semibold hover:bg-white/90 transition-all focus:outline-none focus:ring-2 focus:ring-white/50 focus:ring-offset-2 focus:ring-offset-transparent"
            >
              {{ section.settings.button_text }}
              <svg class="ml-2 w-4 h-4 transition-transform group-hover:translate-x-0.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round">
                <line x1="5" y1="12" x2="19" y2="12"></line>
                <polyline points="12 5 19 12 12 19"></polyline>
              </svg>
            </a>
          {% endif %}

          {% if section.settings.secondary_button_text != blank %}
            <a
              href="{{ section.settings.secondary_button_link }}"
              class="inline-flex items-center px-6 py-3 bg-white/10 text-white rounded-full text-sm font-semibold hover:bg-white/20 transition-all border border-white/[0.12] focus:outline-none focus:ring-2 focus:ring-white/30"
            >
              {{ section.settings.secondary_button_text }}
            </a>
          {% endif %}
        </div>
      </div>

      <div class="col-span-1 glass-surface rounded-3xl p-5 sm:p-6 flex flex-col justify-between haptic-hover overflow-hidden relative group">
        {% if section.settings.card_1_image != blank %}
          <img
            src="{{ section.settings.card_1_image | image_url: width: 600 }}"
            alt="{{ section.settings.card_1_image.alt | escape }}"
            loading="lazy"
            class="absolute inset-0 w-full h-full object-cover opacity-40 group-hover:opacity-50 transition-opacity"
          >
        {% endif %}
        <div class="relative z-10">
          <div class="w-10 h-10 rounded-2xl bg-gradient-to-br from-orange-400 to-pink-500 flex items-center justify-center mb-3" aria-hidden="true">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2">
              <path d="M12 2L2 7l10 5 10-5-10-5z"></path>
              <path d="M2 17l10 5 10-5"></path>
              <path d="M2 12l10 5 10-5"></path>
            </svg>
          </div>
          <h3 class="text-sm font-semibold text-white mb-1">{{ section.settings.card_1_title | default: 'Premium Quality' }}</h3>
          <p class="text-xs text-white/50 leading-relaxed">{{ section.settings.card_1_text | default: 'Crafted with the finest materials' }}</p>
        </div>
      </div>

      <div class="col-span-1 glass-surface rounded-3xl p-5 sm:p-6 flex flex-col justify-between haptic-hover overflow-hidden relative group">
        {% if section.settings.card_2_image != blank %}
          <img
            src="{{ section.settings.card_2_image | image_url: width: 600 }}"
            alt="{{ section.settings.card_2_image.alt | escape }}"
            loading="lazy"
            class="absolute inset-0 w-full h-full object-cover opacity-40 group-hover:opacity-50 transition-opacity"
          >
        {% endif %}
        <div class="relative z-10">
          <div class="w-10 h-10 rounded-2xl bg-gradient-to-br from-green-400 to-emerald-600 flex items-center justify-center mb-3" aria-hidden="true">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2">
              <path d="M22 11.08V12a10 10 0 11-5.93-9.14"></path>
              <polyline points="22 4 12 14.01 9 11.01"></polyline>
            </svg>
          </div>
          <h3 class="text-sm font-semibold text-white mb-1">{{ section.settings.card_2_title | default: 'Free Shipping' }}</h3>
          <p class="text-xs text-white/50 leading-relaxed">{{ section.settings.card_2_text | default: 'Complimentary on all orders' }}</p>
        </div>
      </div>

      <div class="col-span-1 glass-surface rounded-3xl p-5 sm:p-6 flex flex-col justify-between haptic-hover overflow-hidden relative group">
        {% if section.settings.card_3_image != blank %}
          <img
            src="{{ section.settings.card_3_image | image_url: width: 600 }}"
            alt="{{ section.settings.card_3_image.alt | escape }}"
            loading="lazy"
            class="absolute inset-0 w-full h-full object-cover opacity-40 group-hover:opacity-50 transition-opacity"
          >
        {% endif %}
        <div class="relative z-10">
          <div class="w-10 h-10 rounded-2xl bg-gradient-to-br from-blue-400 to-indigo-600 flex items-center justify-center mb-3" aria-hidden="true">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2">
              <rect x="3" y="11" width="18" height="11" rx="2" ry="2"></rect>
              <path d="M7 11V7a5 5 0 0110 0v4"></path>
            </svg>
          </div>
          <h3 class="text-sm font-semibold text-white mb-1">{{ section.settings.card_3_title | default: 'Secure Checkout' }}</h3>
          <p class="text-xs text-white/50 leading-relaxed">{{ section.settings.card_3_text | default: 'Encrypted & protected payments' }}</p>
        </div>
      </div>

      <div class="col-span-1 glass-surface rounded-3xl p-5 sm:p-6 flex flex-col justify-between haptic-hover overflow-hidden relative group">
        {% if section.settings.card_4_image != blank %}
          <img
            src="{{ section.settings.card_4_image | image_url: width: 600 }}"
            alt="{{ section.settings.card_4_image.alt | escape }}"
            loading="lazy"
            class="absolute inset-0 w-full h-full object-cover opacity-40 group-hover:opacity-50 transition-opacity"
          >
        {% endif %}
        <div class="relative z-10">
          <div class="w-10 h-10 rounded-2xl bg-gradient-to-br from-purple-400 to-violet-600 flex items-center justify-center mb-3" aria-hidden="true">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2">
              <path d="M21 15a2 2 0 01-2 2H7l-4 4V5a2 2 0 012-2h14a2 2 0 012 2z"></path>
            </svg>
          </div>
          <h3 class="text-sm font-semibold text-white mb-1">{{ section.settings.card_4_title | default: '24/7 Support' }}</h3>
          <p class="text-xs text-white/50 leading-relaxed">{{ section.settings.card_4_text | default: 'Always here to help you' }}</p>
        </div>
      </div>

    </div>
  </div>
</section>

{% schema %}
{
  "name": "Bento Hero",
  "tag": "section",
  "class": "bento-hero-section",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow text",
      "default": "New Collection"
    },
    {
      "type": "text",
