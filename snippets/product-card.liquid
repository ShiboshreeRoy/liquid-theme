<article class="glass-surface rounded-3xl overflow-hidden haptic-hover group" aria-label="{{ product.title | escape }}">
  <a href="{{ product.url }}" class="block focus:outline-none focus-visible:ring-2 focus-visible:ring-white/50 focus-visible:ring-inset rounded-3xl">
    <div class="aspect-square overflow-hidden relative">
      {% if product.featured_image != blank %}
        <img
          src="{{ product.featured_image | image_url: width: 600 }}"
          alt="{{ product.featured_image.alt | default: product.title | escape }}"
          width="600"
          height="600"
          loading="lazy"
          class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105"
        >
      {% else %}
        <div class="w-full h-full bg-white/5 flex items-center justify-center">
          <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1" class="text-white/20">
            <rect x="3" y="3" width="18" height="18" rx="2" ry="2"></rect>
            <circle cx="8.5" cy="8.5" r="1.5"></circle>
            <polyline points="21 15 16 10 5 21"></polyline>
          </svg>
        </div>
      {% endif %}

      {% if product.compare_at_price > product.price %}
        <span class="absolute top-3 left-3 px-2.5 py-1 text-[10px] font-bold uppercase tracking-wider bg-red-500 text-white rounded-full">
          {{ 'product.sale' | t }}
        </span>
      {% endif %}

      {% unless product.available %}
        <span class="absolute top-3 left-3 px-2.5 py-1 text-[10px] font-bold uppercase tracking-wider bg-white/20 text-white rounded-full backdrop-blur-sm">
          {{ 'product.sold_out' | t }}
        </span>
      {% endunless %}
    </div>

    <div class="p-4">
      {% if product.vendor != blank %}
        <p class="text-[10px] font-medium text-white/30 uppercase tracking-wider mb-1">{{ product.vendor }}</p>
      {% endif %}

      <h3 class="text-sm font-semibold text-white truncate mb-1.5 group-hover:text-white/90 transition-colors">
        {{ product.title }}
      </h3>

      <div class="flex items-baseline gap-2">
        <span class="text-sm font-semibold text-white">{{ product.price | money }}</span>
        {% if product.compare_at_price > product.price %}
          <span class="text-xs text-white/30 line-through">{{ product.compare_at_price | money }}</span>
        {% endif %}
      </div>

      {% if product.options.size > 1 or product.variants.size > 1 %}
        <p class="text-[10px] text-white/30 mt-2">
          {{ product.variants.size }} {{ 'product.options_available' | t }}
        </p>
      {% endif %}
    </div>
  </a>
</article>